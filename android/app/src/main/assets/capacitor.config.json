{
	"appId": "com.rhombuschess4d.app",
	"appName": "4D Rhombus Chess",
	"webDir": "www",
	"server": {
		"androidScheme": "https"
	},
	"android": {
		"allowMixedContent": false,
		"backgroundColor": "#000000"
	},
	"ios": {
		"backgroundColor": "#000000",
		"contentInset": "always"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"backgroundColor": "#000000",
			"showSpinner": false,
			"androidScaleType": "CENTER_CROP"
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#000000"
		}
	}
}
